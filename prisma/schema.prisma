// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

model Role {
  id    String   @id @default(cuid())
  name  RoleName @unique
  users User[]
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  roleId         String
  role           Role           @relation(fields: [roleId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sessions       Session[]
  comments       Comment[]
  reviews        Review[]
  ratings        Rating[]
  watchlists     Watchlist[]
  favorites      Favorite[]
  watchHistory   WatchHistory[]
  notifications  Notification[]
  reportsFiled   Report[]       @relation("Reporter")
  reportsAgainst Report[]       @relation("TargetUser")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AnimeStatus {
  AIRING
  COMPLETED
  UPCOMING
}

model Genre {
  id    String  @id @default(cuid())
  name  String  @unique
  anime Anime[]
}

model Studio {
  id    String  @id @default(cuid())
  name  String  @unique
  anime Anime[]
}

model Anime {
  id            String      @id @default(cuid())
  comments      Comment[]
  reviews       Review[]
  ratings       Rating[]
  watchlist     Watchlist[]
  favorites     Favorite[]
  title         String
  titleJp       String?
  synopsis      String      @db.Text
  poster        String?
  banner        String?
  releaseDate   DateTime?
  status        AnimeStatus @default(UPCOMING)
  episodesCount Int         @default(0)
  trailerUrl    String?
  rating        Float       @default(0)

  genres   Genre[]
  studios  Studio[]
  episodes Episode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Episode {
  id           String         @id @default(cuid())
  comments     Comment[]
  watchHistory WatchHistory[]
  number       Int
  title        String?
  description  String?        @db.Text
  airDate      DateTime?
  duration     Int? // in minutes

  animeId String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  videos    Video[]
  subtitles Subtitle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([animeId, number])
}

model Video {
  id      String @id @default(cuid())
  url     String
  quality String // 360p, 480p, 720p, 1080p, etc.
  format  String // mp4, hls, etc.

  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subtitle {
  id       String @id @default(cuid())
  url      String
  language String

  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id   String @id @default(cuid())
  text String @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  animeId String?
  anime   Anime?  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  episodeId String?
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reports   Report[]
}

model Review {
  id      String @id @default(cuid())
  content String @db.Text
  rating  Int    @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  animeId String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reports   Report[]
}

model Rating {
  id    String @id @default(cuid())
  value Int

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  animeId String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, animeId])
}

model Watchlist {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  animeId String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, animeId])
}

model Favorite {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  animeId String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, animeId])
}

model WatchHistory {
  id       String @id @default(cuid())
  progress Int    @default(0) // in seconds

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, episodeId])
}

model Notification {
  id      String  @id @default(cuid())
  title   String
  message String
  isRead  Boolean @default(false)
  url     String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Advertisement {
  id        String  @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String
  placement String // HOMEPAGE, SIDEBAR, PLAYER_OVERLAY, etc.
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String  @db.Text
  description String?

  updatedAt DateTime @updatedAt
}

model Report {
  id     String @id @default(cuid())
  reason String
  status String @default("PENDING") // PENDING, RESOLVED, DISMISSED

  reporterId String
  reporter   User   @relation("Reporter", fields: [reporterId], references: [id])

  targetUserId String?
  targetUser   User?   @relation("TargetUser", fields: [targetUserId], references: [id])

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id])

  reviewId String?
  review   Review? @relation(fields: [reviewId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
